{
  "openapi": "3.0.0",
  "info": {
    "title": "Teleporte API",
    "version": "1.0.0",
    "description": "API for collecting and managing chat logs for the Teleporte system."
  },
  "servers": [
    {
      "url": "https://teleporte.odd-scene-3e1d.workers.dev"
    }
  ],
  "paths": {
    "/api/collect-log": {
      "post": {
        "summary": "Submit a new log",
        "description": "Submits a new chat log or piece of information to be collected and processed later.",
        "operationId": "submitLog",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "content": {
                    "type": "string",
                    "description": "The full content of the log being submitted. This is the primary data."
                  },
                  "title": {
                    "type": "string",
                    "description": "An optional title for the submission."
                  },
                  "source_chat": {
                    "type": "string",
                    "description": "Optional field to describe the source of the log, e.g., 'ChatGPT Session with Gemini'."
                  },
                  "tags": {
                    "type": "string",
                    "description": "Optional comma-separated list of tags."
                  },
                  "confidence_level": {
                    "type": "string",
                    "description": "Optional confidence level (e.g., 'High', 'Medium', 'Low')."
                  }
                },
                "required": ["content"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Log submitted successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "id": {
                      "type": "integer"
                    },
                    "organized": {
                        "type": "boolean"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Missing required content."
          },
          "500": {
            "description": "Internal Server Error."
          }
        }
      }
    }
  }
}
