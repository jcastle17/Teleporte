{
  "openapi": "3.1.0",
  "info": {
    "title": "Teleporte API",
    "version": "1.0.0",
    "description": "API for saving chat logs into the Teleporte system."
  },
  "servers": [
    {
      "url": "https://teleporte.odd-scene-3e1d.workers.dev"
    }
  ],
  "paths": {
    "/api/collect-log": {
      "post": {
        "operationId": "submitLog",
        "summary": "Submit a chat log to Teleporte",
        "description": "Saves a chat log or handoff note into the Teleporte system.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string",
                    "description": "Short title for the chat log."
                  },
                  "content": {
                    "type": "string",
                    "description": "The complete chat log, handoff log, or markdown content to save."
                  }
                },
                "required": ["title", "content"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Log submitted successfully."
          }
        }
      }
    }
  }
}
